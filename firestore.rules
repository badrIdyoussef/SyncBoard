rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Task Validation Blueprint
    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status', 'priority', 'userId', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 6 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.status in ['todo', 'in-progress', 'completed'] &&
             data.priority in ['low', 'medium', 'high'] &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    match /tasks/{taskId} {
      // Identity Hardening (Pillar 3)
      allow get: if isOwner(existing().userId) && isValidId(taskId);
      
      // Secure List Queries (Pillar 8)
      // Forces client to use .where('userId', '==', uid)
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() && isValidTask(incoming());

      allow update: if isOwner(existing().userId) &&
                    isValidId(taskId) &&
                    // Ensure userId is immutable (Pillar 9)
                    incoming().userId == existing().userId &&
                    // Ensure createdAt is immutable (Pillar 9)
                    incoming().createdAt == existing().createdAt &&
                    // Ensure updatedAt is updated correctly (Pillar 10)
                    incoming().updatedAt == request.time &&
                    // Action-Based patterns (Pillar 4)
                    (
                      // Action: Full Update (Title/Priority change)
                      (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'priority', 'status', 'updatedAt']) && 
                       incoming().title is string && incoming().title.size() > 0) ||
                      // Action: Status toggle only
                      (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && 
                       incoming().status in ['todo', 'in-progress', 'completed'])
                    );

      allow delete: if isOwner(existing().userId) && isValidId(taskId);
    }
  }
}
